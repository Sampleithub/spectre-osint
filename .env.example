# LLM Provider: "ollama" (default, free) or "openai"
LLM_PROVIDER=ollama

# For Ollama (default)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1

# For OpenAI (uncomment and set key to use)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4o

MAX_TOKENS=4096
TEMPERATURE=0.7
MAX_INVESTIGATION_ROUNDS=25
SECRET_KEY=change-me-in-production
HOST=0.0.0.0
PORT=8000
